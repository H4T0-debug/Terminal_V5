end

local function extractCode(text)
    local pattern = "```lua\n(.-)\n```"
    local code = text:match(pattern)
    if not code then
        pattern = "```\n(.-)\n```"
        code = text:match(pattern)
    end
    return code
end

-- Helper to convert custom library to valid back-up lua module string
local function convertTableToLuaString(tbl)
    local raw = "local ScriptLibrary = {\n    Catalog = {\n"
    for _, item in ipairs(tbl) do
        raw = raw .. "        {\n"
        raw = raw .. "            Name = [[" .. tostring(item.Name) .. "]],\n"
        raw = raw .. "            Game = [[" .. tostring(item.Game) .. "]],\n"
        raw = raw .. "            RawCode = [[" .. tostring(item.RawCode) .. "]],\n"
        raw = raw .. "            Execute = function()\n                " .. tostring(item.RawCode):gsub("\n", "\n                ") .. "\n            end\n"
        raw = raw .. "        },\n"
    end
    raw = raw .. "    }\n}\nreturn ScriptLibrary"
    return raw
end

