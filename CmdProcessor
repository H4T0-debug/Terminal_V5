end

local function getNearestTrashcan()
    local nearest = nil
    local shortestDist = 1000
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Name:lower() == TRASH_NAME then
            if obj.Transparency < 1 and obj.CanCollide == true then
                local isHeld = false
                for _, p in pairs(Players:GetPlayers()) do
                    if p.Character and obj:IsDescendantOf(p.Character) then isHeld = true break end
                end
                if not isHeld then
                    local dist = (hrp.Position - obj.Position).Magnitude
