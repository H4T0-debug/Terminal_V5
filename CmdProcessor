function API.AskAI(message)
    if message:lower():find("run this code") then
        uiRef.AiOutputLabel.Text = uiRef.AiOutputLabel.Text .. "\n\n<b>" .. player.Name .. ":</b> " .. message
        if states.lastAiCode ~= "" then
            uiRef.AiOutputLabel.Text = uiRef.AiOutputLabel.Text .. "\n<b>Termin:</b> Executing cached script..."
            uiRef.AiScroll.CanvasPosition = Vector2.new(0, 99999)
            local success, err = pcall(function()
                local func = loadstring(states.lastAiCode)
                if func then task.spawn(func) else error("Failed to load script (Syntax Error)") end
            end)
            if success then
                uiRef.AiOutputLabel.Text = uiRef.AiOutputLabel.Text .. "\n<b>Termin:</b> Script executed successfully."
            else
                uiRef.AiOutputLabel.Text = uiRef.AiOutputLabel.Text .. "\n<b>Termin:</b> Execution Error: " .. tostring(err)
            end
        else
            uiRef.AiOutputLabel.Text = uiRef.AiOutputLabel.Text .. "\n<b>Termin:</b> Error: No script found in previous message to execute."
        end
        uiRef.AiScroll.CanvasPosition = Vector2.new(0, 99999)
        return
    end

	uiRef.AiOutputLabel.Text = uiRef.AiOutputLabel.Text .. "\n\n<b>" .. player.Name .. ":</b> " .. message
	uiRef.AiOutputLabel.Text = uiRef.AiOutputLabel.Text .. "\n<b>Termin:</b> <i>Thinking...</i>"
	uiRef.AiScroll.CanvasPosition = Vector2.new(0, 99999)

	task.spawn(function()
		local requestFunc = (syn and syn.request) or (http and http.request) or http_request or request
		if not requestFunc then 
			uiRef.AiOutputLabel.Text = uiRef.AiOutputLabel.Text:gsub("\n<b>Termin:</b> <i>Thinking.*</i>", "\n<b>Termin:</b> Error: Executor does not support requests.")
			return 
		end

		local response = requestFunc({
			Url = "https://openrouter.ai/api/v1/chat/completions",
			Method = "POST",
			Headers = {
				["Content-Type"] = "application/json",
				["Authorization"] = "Bearer " .. uiRef.APIKey,
                ["HTTP-Referer"] = "https://roblox.com",
                ["X-Title"] = "Roblox Terminal"
			},
			Body = HttpService:JSONEncode({
				model = "nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free", 
				messages = {
                    {
                        role = "system", 
                        content = "You are Termin AI. You are integrated into Terminal V5.0. You receive live game hierarchy data. ALWAYS reference the data provided in the user's message as it is current. Identify vulnerabilities or scripts. IMPORTANT: Only provide scripts in ```lua ... ``` blocks."
                    },
					{role = "user", content = "CURRENT_GAME_DATA: " .. states.lastScrapedData .. "\n\nUSER_MESSAGE: " .. message}
				},
				max_tokens = 1000
			}),
            Timeout = 60
		})

		if response.Success then
			local success, data = pcall(function() return HttpService:JSONDecode(response.Body) end)
            if success and data and data.choices and data.choices[1] and data.choices[1].message then
                local msgData = data.choices[1].message
			    local reply = msgData.content or ""
                
                if reply == "" then
                    uiRef.AiOutputLabel.Text = uiRef.AiOutputLabel.Text:gsub("\n<b>Termin:</b> <i>Thinking.*</i>", "\n<b>Termin:</b> Empty response received.")
                else
