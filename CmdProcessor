local function sysLog(text, isSystem, isError)
    -- Log to CLI Theme Console if reference active
    if uiRef.OutputLabel then
        local color = isError and "rgb(255, 100, 100)" or (isSystem and "rgb(0, 255, 255)" or "rgb(0, 255, 0)")
        uiRef.OutputLabel.Text = uiRef.OutputLabel.Text .. string.format("\n<font color='%s'>%s%s</font>", color, isSystem and "[SYSTEM] " or "", text)
        task.wait(0.05)
        uiRef.CmdScroll.CanvasPosition = Vector2.new(0, 99999)
    end
    
    -- Log to Fullscreen Default Theme Console if reference active
    if uiRef.DefaultLog then
        local color = isError and Color3.fromRGB(255, 100, 100) or Color3.fromRGB(0, 160, 255)
        uiRef.DefaultLog(text, color)
    end
end

local function getPlayer(name)
    name = name:lower():gsub("%s+", "")
    for _, p in pairs(Players:GetPlayers()) do
        if p.Name:lower():sub(1, #name) == name or p.DisplayName:lower():sub(1, #name) == name then
            return p
        end
    end
    return nil
end

local function findObjectDeep(name)
    for _, obj in pairs(game:GetDescendants()) do
        if obj.Name == name and (obj:IsA("BasePart") or obj:IsA("Model")) then
            return obj
        end
    end
    return nil
end

local function getNearestTrashcan()
    local nearest = nil
    local shortestDist = 1000
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Name:lower() == TRASH_NAME then
            if obj.Transparency < 1 and obj.CanCollide == true then
                local isHeld = false
                for _, p in pairs(Players:GetPlayers()) do
                    if p.Character and obj:IsDescendantOf(p.Character) then isHeld = true break end
                end
                if not isHeld then
                    local dist = (hrp.Position - obj.Position).Magnitude
                    if dist < shortestDist then shortestDist = dist nearest = obj end
                end
            end
        end
    end
    return nearest
end

local function extractCode(text)
    local pattern = "```lua\n(.-)\n```"
    local code = text:match(pattern)
    if not code then
        pattern = "```\n(.-)\n```"
        code = text:match(pattern)
    end
    return code
end

-- Helper to convert custom library to valid back-up lua module string
local function convertTableToLuaString(tbl)
    local raw = "local ScriptLibrary = {\n    Catalog = {\n"
    for _, item in ipairs(tbl) do
        raw = raw .. "        {\n"
        raw = raw .. "            Name = [[" .. tostring(item.Name) .. "]],\n"
        raw = raw .. "            Game = [[" .. tostring(item.Game) .. "]],\n"
        raw = raw .. "            RawCode = [[" .. tostring(item.RawCode) .. "]],\n"
        raw = raw .. "            Execute = function()\n                " .. tostring(item.RawCode):gsub("\n", "\n                ") .. "\n            end\n"
        raw = raw .. "        },\n"
    end
    raw = raw .. "    }\n}\nreturn ScriptLibrary"
    return raw
end

