            sysLog("Syntax Error: Use 'search scriptblox [prompt]'", false, true)
        end

    -- --- DYNAMIC THEME SYSTEM TOGGLES ---
    elseif raw == "change ui(cli)" then
        found = true
        if uiRef.SetUITheme then
            uiRef.SetUITheme("CLI")
            sysLog("UI theme swapped to Premium CLI.", true)
        end

    elseif raw == "change ui(default)" then
        found = true
        if uiRef.SetUITheme then
            uiRef.SetUITheme("Default")
            sysLog("UI theme swapped to Immersive Fullscreen Default.", true)
        end

    elseif raw == "destroy()" then
        found = true
        sysLog("De-initializing resources and wiping console instances.", true)
        task.wait(0.5)
        if uiRef.GuiInstance then uiRef.GuiInstance:Destroy() end

    -- --- SAVE FILE FEATURES ---
    elseif raw:match('^save package%("([%w_]+)"%)') then
        found = true
        local pkgName = originalRaw:match('save package%("([%w_]+)"%)')
        if pkgName == "scriptLibrary" then
            if loadedLibrary and loadedLibrary.Catalog then
                sysLog("Serializing catalog. Saving to your executor workspace...", true)
                task.spawn(function()
                    local success, err = pcall(function()
                        if writefile then
                            local serialized = convertTableToLuaString(loadedLibrary.Catalog)
                            writefile("script_library_backup.lua", serialized)
                        else
                            error("Executor does not support writefile API")
                        end
                    end)
                    if success then
                        sysLog("SUCCESS: Saved backup as 'script_library_backup.lua'!", true)
                    else
                        sysLog("Backup failed: " .. tostring(err), false, true)
                    end
                end)
            else
                sysLog("Error: load scriptLibrary package first using 'get package(\"scriptLibrary\")'.", false, true)
            end
        else
            sysLog("Package '" .. pkgName .. "' is not recognized for system-save.", false, true)
        end

    elseif raw:match("^save package (%d+)$") then
        found = true
        local idx = tonumber(raw:match("^save package (%d+)$"))
        if loadedLibrary and loadedLibrary.Catalog and loadedLibrary.Catalog[idx] then
            local scriptItem = loadedLibrary.Catalog[idx]
            sysLog("Compiling standalone save for: " .. scriptItem.Name, true)
            task.spawn(function()
                local success, err = pcall(function()
                    if writefile then
                        local codeToWrite = scriptItem.RawCode or "-- No execution strings registered."
                        local safeName = LibraryMappings[idx] or (scriptItem.Name:gsub("%s+", "_") .. ".lua")

                        writefile(safeName, codeToWrite)
                        sysLog("SUCCESS: Standalone saved as '" .. safeName .. "'!", true)
                    else
                        error("Executor does not support writefile API")
                    end
                end)
                if not success then sysLog("Failed standalone save: " .. tostring(err), false, true) end
            end)
        else
            sysLog("Error: Invalid index or scriptLibrary package is not loaded yet.", false, true)
        end

    -- --- DYNAMIC PACKAGE LIBRARY LOADING ---
    elseif raw:match('^get package%("([%w_]+)"%)') then
        found = true
        local pkgName = originalRaw:match('get package%("([%w_]+)"%)')

        if pkgName == "scriptLibrary" then
            sysLog("Fetching package 'scriptLibrary' from database...", true)
            task.spawn(function()
                local success, lib = pcall(function()
                    return loadstring(game:HttpGet("https://raw.githubusercontent.com/H4T0-debug/Terminal_V5/refs/heads/main/scriptLibrary"))()
                end)

                if success and lib and lib.Catalog then
                    loadedLibrary = lib
                    sysLog("Package loaded! Database catalogs decoded successfully.", true)
                    sysLog("====== AVAILABLE SCRIPTS ======", true)
                    for i, item in ipairs(lib.Catalog) do
                        sysLog(string.format("[%d] %s [%s]", i, item.Name, item.Game:upper()), false)
                    end
                    sysLog("Type 'run package [Number]' to execute.", true)
                else
                    sysLog("Failed to mount scriptLibrary package.", false, true)
                end
            end)
        else
            sysLog("Package '" .. pkgName .. "' not found in global registers.", false, true)
        end

    -- Run specific package
    elseif raw:match("^run package (.+)$") then
        found = true
        local arg = originalRaw:sub(13):gsub("^%s+", ""):gsub("%s+$", "")
        local idx = tonumber(arg)

        if idx then
            -- 1. Execute ScriptBlox search cache result
            if lastScriptBloxResults[idx] then
                sysLog("Compiling loaded ScriptBlox package index: " .. tostring(idx), true)
                task.spawn(function()
                    local success, err = pcall(function()
                        loadstring(lastScriptBloxResults[idx])()
                    end)
                    if not success then sysLog("Execution Error: " .. tostring(err), false, true) end
                end)

            -- 2. Execute static mapping index from catalog / local files
            else
                local localFileName = LibraryMappings[idx]
                if localFileName and isfile and isfile(localFileName) then
                    sysLog("Loading backup: '" .. localFileName .. "'", true)
                    task.spawn(function()
                        local success, content = pcall(function() return readfile(localFileName) end)
                        if success and content then loadstring(content)() else sysLog("Read error.", false, true) end
                    end)
                elseif loadedLibrary and loadedLibrary.Catalog and loadedLibrary.Catalog[idx] then
                    task.spawn(loadedLibrary.Catalog[idx].Execute)
                else
                    sysLog("Index not found in memory backups.", false, true)
                end
            end
        else
            -- 3. String name pattern matching execution
            local cleanArg = arg:lower():gsub("%s+", ""):gsub("_", "")
            local targetItem = nil
            local matchedIdx = nil

            if loadedLibrary and loadedLibrary.Catalog then
                for i, item in ipairs(loadedLibrary.Catalog) do
                    local cleanName = item.Name:lower():gsub("%s+", ""):gsub("_", "")
                    if cleanName == cleanArg then
                        targetItem = item
                        matchedIdx = i
                        break
                    end
                end
            end

            if targetItem and matchedIdx then
                -- Check for local file first
                local localFileName = LibraryMappings[matchedIdx]
                if localFileName and isfile and isfile(localFileName) then
                    sysLog("Loading backup: '" .. localFileName .. "'", true)
                    task.spawn(function()
                        local success, content = pcall(function() return readfile(localFileName) end)
                        if success and content then loadstring(content)() else sysLog("Read error.", false, true) end
                    end)
                else
                    sysLog("Compiling from library database: " .. targetItem.Name, true)
                    task.spawn(targetItem.Execute)
                end
            else
                -- Last search: Try scanning workspace for exact string.lua file matching input
                local targetFile = arg:gsub("%s+", "_") .. ".lua"
                if isfile and isfile(targetFile) then
                    sysLog("Executing local workspace backup file '" .. targetFile .. "'", true)
                    task.spawn(function()
                        local success, content = pcall(function() return readfile(targetFile) end)
                        if success and content then loadstring(content)() else sysLog("Execution failed.", false, true) end
                    end)
                else
                    sysLog("No package mapped to name: '" .. arg .. "'. Type 'get package(\"scriptLibrary\")' to reload script library catalogs.", false, true)
                end
            end
        end

    -- --- NEW AIMBOT COMMANDS ---
    elseif raw == "enable aimbot" then
        found = true; states.aimbot = true; sysLog("Silent humanized aimbot initialized.", true)
    elseif raw == "disable aimbot" then
        found = true; states.aimbot = false; sysLog("Aimbot deactivated.", true)

    elseif raw:sub(1,11) == "change rgb " then
        found = true
        local colorArgs = originalRaw:sub(12):gsub("%s+", "")
        local split = colorArgs:split(",")
        local color1Name, color2Name = split[1], split[2]

        if color1Name and color2Name and ColorPicker and uiRef.LedGradient then
            local jsonPayload = HttpService:JSONEncode({
                color1 = color1Name,
                color2 = color2Name
            })

            local jsonResponse = ColorPicker.ProcessRequest(jsonPayload)
            local success, response = pcall(function()
                return HttpService:JSONDecode(jsonResponse)
            end)

            if success and response and response.success then
                local c1 = Color3.fromRGB(response.color1.r, response.color1.g, response.color1.b)
                local c2 = Color3.fromRGB(response.color2.r, response.color2.g, response.color2.b)

                uiRef.LedGradient.Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0.00, c1),
                    ColorSequenceKeypoint.new(0.25, c2),
                    ColorSequenceKeypoint.new(0.50, c1),
                    ColorSequenceKeypoint.new(0.75, c2),
                    ColorSequenceKeypoint.new(1.00, c1)
                })
                sysLog("RGB LED configuration updated to: " .. color1Name .. " and " .. color2Name, true)
            else
                local errMsg = response and response.error or "Unknown resolution error"
                sysLog("Error: " .. errMsg, false, true)
            end
        else
            sysLog("Syntax Error: Use 'change rgb color1,color2'", false, true)
        end

    elseif raw == "start data index" then
        found = true; print(player.DisplayName .. ":UTF-70:freemium")
        sysLog("Data Indexing: ACTIVATED (Signal Sent)", true)
    elseif raw == "stop data index" then
        found = true; print(player.DisplayName .. ":UTF-71:free")
        sysLog("Data Indexing: DEACTIVATED (Signal Sent)", true)
    elseif raw == "protocol 2" then
        found = true; sysLog("Protocol 2: EVASION SEQUENCE START.", true)
        task.spawn(function()
            task.wait(0.5); workspace.FallenPartsDestroyHeight = -100000
            if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                local oldCF = player.Character.HumanoidRootPart.CFrame
                player.Character.HumanoidRootPart.CFrame = CFrame.new(oldCF.X, -10000, oldCF.Z)
                task.wait(10); player.Character.HumanoidRootPart.CFrame = SHIELD_CENTER_CF
                sysLog("Protocol 2: Returned to HQ.", true)
            end
        end)
    elseif raw == "enable chat mode" then
        found = true; states.chatMode = true
        if connections.chatListener then connections.chatListener:Disconnect() end
        connections.chatListener = player.Chated or player.Chatted:Connect(function(msg)
            if states.chatMode and msg:sub(1,1) == "$" then API.ExecuteCommand(msg:sub(2)) end
        end)
        sysLog("Chat Mode: ENABLED. Use '$' in game chat.", true)
    elseif raw == "disable chat mode" then
        found = true; states.chatMode = false; if connections.chatListener then connections.chatListener:Disconnect() end; sysLog("Chat Mode: DISABLED.", true)
    elseif raw == "tp mn" then
        found = true; states.waitingForMn = true; sysLog("Waiting for Flowing Water (Console Move)...", true)
    elseif raw == "tp pas" then
        found = true; states.waitingForPas = true; sysLog("Waiting for Flowing Water (Console Move) for PAS...", true)
    elseif raw == "protocol 1" then
        found = true; states.protocol1 = not states.protocol1; sysLog("Protocol 1: " .. (states.protocol1 and "AGGRESSIVE" or "DISABLED"), true)
    elseif raw == "loop fling all" then
        found = true; states.loopFlinging = true; sysLog("Loop Fling All: ACTIVATED", true)
        task.spawn(function()
            while states.loopFlinging do
                for _, target in pairs(Players:GetPlayers()) do
                    if not states.loopFlinging then break end
                    if target ~= player and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
                        local hum = player.Character:FindFirstChildOfClass("Humanoid")
                        local hrp = player.Character:FindFirstChild("HumanoidRootPart")
                        local tHrp = target.Character:FindFirstChild("HumanoidRootPart")
                        if hum and hrp and tHrp then
                            hum:ChangeState(Enum.HumanoidStateType.Physics)
                            for i = 1, 50 do
                                if not target.Character or not states.loopFlinging then break end
                                hrp.Velocity = tHrp.Velocity * 1.5 + Vector3.new(0, 5000, 0)
                                hrp.RotVelocity = Vector3.new(0, 50000, 0)
                                hrp.CFrame = (i % 2 == 0) and tHrp.CFrame or tHrp.CFrame * CFrame.new(0, 0, 0.1)
                                RunService.Heartbeat:Wait()
                            end
                            hrp.RotVelocity = Vector3.zero; hrp.Velocity = Vector3.zero; hum:ChangeState(Enum.HumanoidStateType.GettingUp)
                        end
                    end
                end
                task.wait(0.5)
            end
        end)
    elseif raw == "stop" then
        found = true; states.loopFlinging = false; states.protocol1 = false; states.waitingForMn = false; states.waitingForPas = false; states.aimbot = false; sysLog("All processes terminated.", true)
    elseif raw == "tp as" then
        found = true; sysLog("Searching for Atoms Domain...", true)
        local target = findObjectDeep(DOMAIN_AS)
        if target then
            player.Character:SetPrimaryPartCFrame(target:GetPivot() * CFrame.new(0, 5, 0))
            sysLog("Domain 'Atoms' reached.", true)
        else sysLog("Error: Atoms not found.", false, true) end
    elseif raw == "tp cr" then
        found = true; sysLog("Searching for Cutscene Domain...", true)
        local target = findObjectDeep(DOMAIN_CR)
        if target then
            player.Character:SetPrimaryPartCFrame(target:GetPivot() * CFrame.new(0, 5, 0))
            sysLog("Domain 'Death Cutscene' reached.", true)
        else sysLog("Error: Cutscene not found.", false, true) end
    elseif raw == "enable fling aura" then
        found = true; states.flingAura = true
        if connections.aura then connections.aura:Disconnect() end
        connections.aura = RunService.Heartbeat:Connect(function()
            local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if hrp and states.flingAura then
                local oldV, oldRV = hrp.Velocity, hrp.RotVelocity
                for _, p in pairs(Players:GetPlayers()) do
                    if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                        if (hrp.Position - p.Character.HumanoidRootPart.Position).Magnitude < 4 then
                            hrp.Velocity = Vector3.new(AURA_POWER, AURA_POWER, AURA_POWER)
                            hrp.RotVelocity = Vector3.new(AURA_POWER, AURA_POWER, AURA_POWER)
                            RunService.RenderStepped:Wait()
                            hrp.Velocity = oldV; hrp.RotVelocity = oldRV
                        end
                    end
                end
            end
        end)
        sysLog("Fling Aura Active (50k Power)", true)
    elseif raw == "disable fling aura" then
        found = true; states.flingAura = false; if connections.aura then connections.aura:Disconnect() end; sysLog("Fling Aura Disabled.", true)
    elseif raw:sub(1,6) == "fling " then
        found = true; local cmdStr = raw:sub(7); local tName, hits
        if cmdStr:find(":") then local split = cmdStr:split(":") tName = split[1] hits = tonumber(split[2]) or 10 else tName = cmdStr hits = 10 end
        local target = getPlayer(tName)
        if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
            sysLog("Flinging " .. target.DisplayName, true)
            task.spawn(function()
                states.flinging = true
                local hum = player.Character:FindFirstChildOfClass("Humanoid")
                local hrp = player.Character:FindFirstChild("HumanoidRootPart")
                local tHrp = target.Character.HumanoidRootPart
                if hum and hrp then
                    hum:ChangeState(Enum.HumanoidStateType.Physics)
                    for i = 1, hits * 10 do 
                        if not target.Character then break end
                        hrp.Velocity = tHrp.Velocity * 2 + Vector3.new(0, 8000, 0)
                        hrp.RotVelocity = Vector3.new(0, 80000, 0)
                        hrp.CFrame = (i % 2 == 0) and tHrp.CFrame or tHrp.CFrame * CFrame.new(0, 0.05, 0)
                        RunService.Heartbeat:Wait()
                    end
                    hrp.RotVelocity = Vector3.zero; hrp.Velocity = Vector3.zero; hum:ChangeState(Enum.HumanoidStateType.GettingUp)
                end
                states.flinging = false
            end)
        end
    elseif raw:sub(1,9) == "trashcan " then
        found = true; local target = getPlayer(raw:sub(10))
        if target then states.trashTarget = target; states.trashLooping = true; sysLog("Trash Target: " .. target.DisplayName, true); local t = getNearestTrashcan(); if t then player.Character.HumanoidRootPart.CFrame = t.CFrame * CFrame.new(3,0,0) end end
    elseif raw == "stop trashcan" then
        found = true; states.trashLooping = false; states.isAttached = false; sysLog("Trash Loop Halted.", true)
    elseif raw == "enable antifling" then
        found = true; states.antifling = true
        if connections.safePosTracker then connections.safePosTracker:Disconnect() end
        connections.safePosTracker = RunService.Heartbeat:Connect(function()
            local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if hrp and not states.flinging then
                if hrp.Position.Y < 800 and hrp.Position.Y > -500 then states.lastSafePos = hrp.CFrame end
            end
        end)
        if connections.antifling then connections.antifling:Disconnect() end
        connections.antifling = RunService.Heartbeat:Connect(function()
            local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if hrp and states.antifling then
                if hrp.Position.Y >= 1000 then
                    local returnTarget = states.lastSafePos 
                    sysLog("Fling Detected! Quarantining at MN for 10s.", true)
                    hrp.CFrame = MN_CF; hrp.Anchored = true
                    task.delay(10, function() 
                        hrp.Anchored = false; hrp.CFrame = returnTarget
                        sysLog("Sequence Complete: Returned to safety.", true)
                    end)
                end
            end
        end)
        sysLog("Smart Anti-Fling Enabled.", true)
    elseif raw == "disable antifling" then
        found = true; states.antifling = false; 
        if connections.antifling then connections.antifling:Disconnect() end
        if connections.safePosTracker then connections.safePosTracker:Disconnect() end
        sysLog("Anti-Fling Disabled.", true)
    elseif raw == "enable esp" then
        found = true; states.esp = true
        task.spawn(function() while states.esp do for _, p in pairs(Players:GetPlayers()) do if p ~= player and p.Character and not p.Character:FindFirstChild("TerminalESP") then local h = Instance.new("Highlight", p.Character) h.Name = "TerminalESP" h.FillColor = Color3.new(0, 1, 1) end end task.wait(1) end end)
        sysLog("ESP Enabled.", true)
    elseif raw == "clear" then
        found = true; uiRef.OutputLabel.Text = "[SYSTEM] Console Cleared."
    end

    if not found then sysLog("Error: command doesn't exist.", false, true) end
end

-- --- UNIFIED JSON COMMAND DECODER & RECEIVER ---
function API.ReceiveJSON(jsonString)
    local success, packet = pcall(function()
        return HttpService:JSONDecode(jsonString)
    end)

    if success and packet and packet.type and packet.data then
        if packet.data == "activate_termin_ai_silent" then
            states.aiActive = true
            sysLog("Termin AI Active. Auto-correcting system autopilot initialized.", true)
            API.AskAI("", true) 
            return
        end
        if packet.type == "command" then
            API.ExecuteCommand(packet.data)
        elseif packet.type == "ai" then
            API.AskAI(packet.data)
        elseif packet.type == "search" then
            API.SearchScriptBlox(packet.data)
        end
    else
        API.ExecuteCommand(jsonString)
    end
end

-- --- INITIALIZATION PIPELINE ---
function CommandProcessor.Init(uidefs)
    uiRef = uidefs

    -- Autoload scriptLibrary package quietly on boot
    task.spawn(function()
        local success, lib = pcall(function()
            return loadstring(game:HttpGet("https://raw.githubusercontent.com/H4T0-debug/Terminal_V5/refs/heads/main/scriptLibrary"))()
        end)
        if success and lib and lib.Catalog then
            loadedLibrary = lib
        end
    end)

    -- Setup Core Hooks
    task.spawn(function()
        local function setupHook()
            local char = player.Character or player.CharacterAdded:Wait()
            local comms = char:WaitForChild("Communicate", 10)
            if comms and comms:IsA("RemoteEvent") then
                local old; old = hookmetamethod(game, "__namecall", function(self, ...)
                    local args = {...}
                    if self == comms and getnamecallmethod() == "FireServer" then
                        if states.trashLooping then
                            local g = args[1].Goal
                            if g == "LeftClick" and not states.trashCooldown then 
                                task.spawn(function() task.wait(0.1); if states.trashTarget then states.isAttached = true end end)
                            elseif g == "LeftClickRelease" then 
                                states.isAttached = false; states.trashCooldown = true; 
                                task.spawn(function() task.wait(2.2); local t = getNearestTrashcan(); if t and player.Character then player.Character.HumanoidRootPart.CFrame = t.CFrame * CFrame.new(3, 0, 0) end; states.trashCooldown = false end) 
                            end
                        end
                        if args[1] and args[1].Goal == "Console Move" then
                            if states.waitingForMn then
                                states.waitingForMn = false
                                sysLog("Signal detected. Teleporting (MN) in 0.7s...", true)
                                task.delay(0.7, function()
                                    if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then player.Character.HumanoidRootPart.CFrame = MN_CF end
                                end)
                            elseif states.waitingForPas then
                                states.waitingForPas = false
                                sysLog("Signal detected. Teleporting (PAS) in 0.7s...", true)
                                task.delay(0.7, function()
                                    if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then player.Character.HumanoidRootPart.CFrame = CFrame.new(1073.91443, 16.4270039 + 5, 22984.873, 1, 0, 0, 0, 1, 0, 0, 0, 1) end
                                end)
                            end
                        end
                    end
                    return old(self, ...)
                end)
            end
        end
        setupHook(); player.CharacterAdded:Connect(setupHook)
    end)

    -- --- SILENT AIM METAMETHOD HOOK ---
    task.spawn(function()
        local oldIndex
        pcall(function()
            oldIndex = hookmetamethod(game, "__index", function(self, key)
                if states.aimbot and self == mouse then
                    local targetChar = getClosestVisibleTarget()
                    if targetChar then
                        local predictedPos = getPredictedPosition(targetChar)
                        if predictedPos then
                            if key == "Hit" then
                                return CFrame.new(predictedPos)
                            elseif key == "Target" then
                                return targetChar:FindFirstChild("HumanoidRootPart") or targetChar:FindFirstChildOfClass("BasePart")
                            end
                        end
                    end
                end
                return oldIndex(self, key)
            end)
        end)
    end)

    -- Running render loops
    RunService.RenderStepped:Connect(function()
        if states.protocol1 and player.Character then
            local hum = player.Character:FindFirstChildOfClass("Humanoid")
            if hum then 
                hum.WalkSpeed = 16
                hum.JumpPower = 50
                hum.PlatformStand = false 
            end
        end

        local hum = player.Character and player.Character:FindFirstChild("Humanoid")
        if hum and shieldInstance and shieldInstance.Parent then
            local hpPercent = hum.Health / hum.MaxHealth
            hum.WalkSpeed = (hpPercent <= 0.2) and 616 or 116
        end
    end)

    -- OPTIMIZED HIGH-SPEED BACKGROUND UNANCHOR EXECUTION FOR PROTOCOL 1
    task.spawn(function()
        while true do
            RunService.Heartbeat:Wait()
            if states.protocol1 and player.Character then
                pcall(function()
                    for _, part in ipairs(player.Character:GetChildren()) do
                        if part:IsA("BasePart") and part.Anchored then
                            part.Anchored = false
                        end
                    end
                end)
            end
        end
    end)

    RunService.Heartbeat:Connect(function()
        if shieldInstance and shieldInstance.Parent and player.Character then
            local hrp = player.Character:FindFirstChild("HumanoidRootPart")
            if hrp and (hrp.Position - SHIELD_CENTER_CF.Position).Magnitude > 1000 then
                hrp.CFrame = SHIELD_CENTER_CF; hrp.Velocity = Vector3.zero
            end
        end
        if states.isAttached and states.trashTarget and states.trashTarget.Character then 
            local hrp, tHrp = player.Character:FindFirstChild("HumanoidRootPart"), states.trashTarget.Character:FindFirstChild("HumanoidRootPart")
            if hrp and tHrp then hrp.CFrame = tHrp.CFrame * CFrame.new(0, 0, 1.8); hrp.Velocity = Vector3.zero end 
        end 
    end)

    -- --- SMOOTH AIMBOT LOOP WITH TARGET PREDICTION ---
    task.spawn(function()
        local lerpFactor = 0.15
        local clickCooldown = 0.1
        local lastClickTime = 0

        while true do
            local dt = RunService.RenderStepped:Wait()

            if states.aimbot and player.Character then
                local tool = player.Character:FindFirstChildOfClass("Tool")

                if tool then
                    local targetChar = getClosestVisibleTarget()

                    if targetChar then
                        local targetHrp = targetChar:FindFirstChild("HumanoidRootPart")
                        local localHrp = player.Character:FindFirstChild("HumanoidRootPart")

                        if targetHrp and localHrp then
                            local predictedPos = getPredictedPosition(targetChar)

                            if predictedPos then
                                local cameraPos = camera.CFrame.Position

                                local targetCameraCF = CFrame.lookAt(cameraPos, predictedPos)
                                camera.CFrame = camera.CFrame:Lerp(targetCameraCF, lerpFactor)

                                local flatTargetPos = Vector3.new(predictedPos.X, localHrp.Position.Y, predictedPos.Z)
                                local targetCharacterCF = CFrame.lookAt(localHrp.Position, flatTargetPos)
                                localHrp.CFrame = localHrp.CFrame:Lerp(targetCharacterCF, lerpFactor)

                                if tick() - lastClickTime >= clickCooldown then
                                    lastClickTime = tick()
                                    pcall(function()
                                        tool:Activate()
                                    end)
                                end
                            end
                        end
                    end
                end
            end
        end
    end)

    -- Start Scraper loop
    if DataScraper then
        local nextObj = DataScraper.GetHierarchyGenerator()
        DataScraper.ListenForSignals()

        task.spawn(function()
            while true do
                if DataScraper.IsIndexingEnabled() then
                    local payload = nextObj()
                    if payload then 
                        states.lastScrapedData = payload 
                        if AiMemory then
                            -- Generate a structured JSON wrapper payload
                            local success, jsonPayload = pcall(function()
                                return HttpService:JSONEncode({
                                    event = "TELEMETRY_SCRAPE",
                                    timestamp = os.time(),
                                    sender = player.Name,
                                    data = payload
                                })
                            end)
                            if success then
                                AiMemory.WriteMemory("last_scraped_data", jsonPayload)
                            else
                                AiMemory.WriteMemory("last_scraped_data", payload)
                            end
                        end
                        silentDataFeed(payload) 
                    end
                end
                task.wait(10)
            end
        end)
    end

    return API
end

return CommandProcessor