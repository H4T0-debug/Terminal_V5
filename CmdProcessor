-- Smart Multi-Theme Console Log Router
local function sysLog(text, isSystem, isError, colorOverride)
    local createdLabel = nil

    if uiRef.OutputLabel then
        local color = isError and "rgb(255, 100, 100)" or (isSystem and "rgb(0, 255, 255)" or "rgb(0, 255, 0)")
        uiRef.OutputLabel.Text = uiRef.OutputLabel.Text .. string.format("\n<font color='%s'>%s%s</font>", color, isSystem and "[SYSTEM] " or "", text)
        task.wait(0.05)
        uiRef.CmdScroll.CanvasPosition = Vector2.new(0, 99999)
    end

    if uiRef.DefaultLog then
        local color = colorOverride or (isError and Color3.fromRGB(255, 100, 100) or Color3.fromRGB(0, 160, 255))
        createdLabel = uiRef.DefaultLog(text, color)
    end

    return createdLabel
end

local function getPlayer(name)
    name = name:lower():gsub("%s+", "")
    for _, p in pairs(Players:GetPlayers()) do
        if p.Name:lower():sub(1, #name) == name or p.DisplayName:lower():sub(1, #name) == name then
            return p
        end
    end
    return nil
end

local function findObjectDeep(name)
