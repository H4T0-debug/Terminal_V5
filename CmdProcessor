                else
                    sysLog("Failed to mount scriptLibrary package.", false, true)
                end
            end)
        else
            sysLog("Package '" .. pkgName .. "' not found in global registers.", false, true)
        end
        
    -- Run specific script index (Scans local workspace backups FIRST)
    elseif raw:match("^run package (%d+)$") then
        found = true
        local idx = tonumber(raw:match("^run package (%d+)$"))
        local localFileName = LibraryMappings[idx]
        
        -- CHECK EXECUTOR DIRECTORY FOR AN OFFLINE BACKUP FIRST
        if localFileName and isfile and isfile(localFileName) then
