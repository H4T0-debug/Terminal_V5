function API.SearchScriptBlox(query)
    lastScriptBloxResults = {}

    local requestFunc = (syn and syn.request) or (http and http.request) or http_request or request
    if not requestFunc then 
        sysLog("Error: Executor request API is unsupported.", false, true)
        return 
    end

    task.spawn(function()
        local url = "https://scriptblox.com/api/script/search?q=" .. HttpService:UrlEncode(query) .. "&mode=free"
        local response = requestFunc({Url = url, Method = "GET"})
        if response.Success then
            local data = HttpService:JSONDecode(response.Body)
            if data and data.result and data.result.scripts then
                sysLog("====== SCRIPTBLOX RESULTS ======", true)
                for i, s in ipairs(data.result.scripts) do
                    lastScriptBloxResults[i] = s.script
                    sysLog(tostring(i) .. ". " .. s.title, false)
                end
                sysLog("Type 'run package [Number]' to execute.", true)
            else
                sysLog("No search results found.", false, true)
            end
        else
            sysLog("Failed to reach ScriptBlox API.", false, true)
        end
    end)
end

function API.ExecuteCommand(rawInput, bypassAI)
    local originalRaw = rawInput:gsub("^%s+", ""):gsub("%s+$", "")
    if originalRaw == "" then return end

    if LoadstringConverter then
        local wasHandled, errorResult = pcall(function()
            return LoadstringConverter.CleanAndExecute(originalRaw, sysLog)
        end)
        if wasHandled and errorResult then return end
    end

    local raw = originalRaw:lower()

    -- Echo command input logs
    if _G.CurrentUITheme == "cli" then
        sysLog("$ " .. raw, false)
    else
        local prefix = (commandCount == 0) and "Enter command: " or "~ "
        sysLog(prefix .. originalRaw, false, false, Color3.fromRGB(255, 255, 255))
    end
    commandCount = commandCount + 1

    -- --- CHECK FOR VALID LOCAL SYSTEM COMMANDS FIRST TO PREVENT INTERCEPTION ---
    local isLocalCommand = false
    local function matches(pattern)
        return raw:match(pattern) ~= nil
    end

    if raw == "control area" or
       raw == "change ui(cli)" or
       raw == "change ui(default)" or
       raw == "destroy()" or
       raw == "close termin ai" or
       matches("^speed%s*%d+") or
       matches("^speed%d+") or
       matches("^change%s+my%s+speed%s+to%s*%d+") or
       matches("^jumppower%s*%d+") or
       matches("^jumppower%d+") or
       matches("^teleport%s*[%d%.%-]+%s*,%s*[%d%.%-]+%s*,%s*[%d%.%-]+") or
       raw:sub(1,17) == "search scriptblox" or
       raw:sub(1,17) == "search scriptblox " or
       raw:match('^save package%("([%w_]+)"%)') or
       raw:match("^save package (%d+)$") or
       raw:match('^get package%("([%w_]+)"%)') or
       raw:match("^run package (.+)$") or
       raw == "enable aimbot" or
       raw == "disable aimbot" or
       raw:sub(1,11) == "change rgb " or
       raw == "start data index" or
       raw == "stop data index" or
       raw == "protocol 2" or
       raw == "enable chat mode" or
       raw == "disable chat mode" or
       raw == "tp mn" or
       raw == "tp pas" or
       raw == "protocol 1" or
       raw == "loop fling all" or
       raw == "stop" or
       raw == "tp as" or
       raw == "tp cr" or
       raw == "enable fling aura" or
       raw == "disable fling aura" or
       raw:sub(1,6) == "fling " or
       raw:sub(1,9) == "trashcan " or
       raw == "stop trashcan" or
       raw == "enable antifling" or
       raw == "disable antifling" or
       raw == "enable esp" or
       raw == "clear" then
        isLocalCommand = true
    end

    -- Check if AI is active and intercept all inputs (except direct commands and deactivators)
    if states.aiActive and not bypassAI and not isLocalCommand then
        API.AskAI(originalRaw)
        return
    end

    local found = false

    if raw == "control area" then found = true; createShield()

    elseif raw == "close termin ai" then
        found = true
        states.aiActive = false
        sysLog("Termin AI Deactivated. Swapping back to default direct pipeline.", true)

    -- --- PLAYER MANIPULATION APIS ---
    elseif raw:match("^speed%s*(%d+)") or raw:match("^change%s+my%s+speed%s+to%s*(%d+)") then
        found = true
        local numStr = raw:match("^speed%s*(%d+)") or raw:match("^change%s+my%s+speed%s+to%s*(%d+)")
        local num = tonumber(numStr)
        if num and player.Character then
            local hum = player.Character:FindFirstChildOfClass("Humanoid")
            if hum then
                hum.WalkSpeed = num
                sysLog("WalkSpeed modified successfully to: " .. tostring(num), true)

                -- Dynamic JSON Event logging to aiMemory
                if AiMemory then
                    local success, jsonPayload = pcall(function()
                        return HttpService:JSONEncode({
                            event = "WALKSPEED_UPDATE",
                            timestamp = os.time(),
                            sender = player.Name,
                            value = num
                        })
                    end)
                    if success then
                        AiMemory.WriteMemory("last_speed_event", jsonPayload)
                    end
                end
            end
        end

    elseif raw:match("^jumppower%s*(%d+)") then
        found = true
        local numStr = raw:match("^jumppower%s*(%d+)")
        local num = tonumber(numStr)
        if num and player.Character then
            local hum = player.Character:FindFirstChildOfClass("Humanoid")
            if hum then
                hum.JumpPower = num
                sysLog("JumpPower modified successfully to: " .. tostring(num), true)

                -- Dynamic JSON Event logging to aiMemory
                if AiMemory then
                    local success, jsonPayload = pcall(function()
                        return HttpService:JSONEncode({
                            event = "JUMPPOWER_UPDATE",
                            timestamp = os.time(),
                            sender = player.Name,
                            value = num
                        })
                    end)
                    if success then
                        AiMemory.WriteMemory("last_jumppower_event", jsonPayload)
                    end
                end
            end
        end

    elseif raw:match("^teleport%s*([%d%.%-]+)%s*,%s*([%d%.%-]+)%s*,%s*([%d%.%-]+)") or raw:match("^teleport%s*([%d%.%-]+)%s+([%d%.%-]+)%s+([%d%.%-]+)") then
        found = true
        local xStr, yStr, zStr = raw:match("^teleport%s*([%d%.%-]+)%s*,%s*([%d%.%-]+)%s*,%s*([%d%.%-]+)")
        if not xStr then
            xStr, yStr, zStr = raw:match("^teleport%s*([%d%.%-]+)%s+([%d%.%-]+)%s+([%d%.%-]+)")
        end
        local x, y, z = tonumber(xStr), tonumber(yStr), tonumber(zStr)
