function API.ExecuteCommand(rawInput)
    local originalRaw = rawInput:gsub("^%s+", ""):gsub("%s+$", "")
    if originalRaw == "" then return end

    if LoadstringConverter then
        local wasHandled, errorResult = pcall(function()
            return LoadstringConverter.CleanAndExecute(originalRaw, sysLog)
        end)
        if wasHandled and errorResult then return end
    end

    local raw = originalRaw:lower()
    
    -- In CLI mode print input echoing, default mode handles it client side
    if _G.CurrentUITheme == "cli" then
        sysLog("$ " .. raw, false)
    end
    
    local found = false
    
    if raw == "control area" then found = true; createShield()
    
    -- --- DYNAMIC THEME SYSTEM TOGGLES ---
    elseif raw == "change ui(cli)" then
        found = true
        if uiRef.SetUITheme then
            uiRef.SetUITheme("CLI")
            sysLog("UI theme swapped to Premium CLI.", true)
        end
        
    elseif raw == "change ui(default)" then
        found = true
        if uiRef.SetUITheme then
            uiRef.SetUITheme("Default")
            sysLog("UI theme swapped to Immersive Fullscreen Default.", true)
        end
        
    elseif raw == "destroy()" then
        found = true
        sysLog("De-initializing resources and wiping console instances.", true)
        task.wait(0.5)
        if uiRef.GuiInstance then
            uiRef.GuiInstance:Destroy()
        end
    
    -- --- SAVE FILE FEATURES ---
    elseif raw:match('^save package%("([%w_]+)"%)') then
        found = true
        local pkgName = originalRaw:match('save package%("([%w_]+)"%)')
        if pkgName == "scriptLibrary" then
            if loadedLibrary and loadedLibrary.Catalog then
                sysLog("Serializing catalog. Saving to your executor workspace...", true)
                task.spawn(function()
                    local success, err = pcall(function()
                        if writefile then
                            local serialized = convertTableToLuaString(loadedLibrary.Catalog)
                            writefile("script_library_backup.lua", serialized)
                        else
                            error("Executor does not support writefile API")
                        end
                    end)
                    if success then
                        sysLog("SUCCESS: Saved backup as 'script_library_backup.lua'!", true)
                    else
                        sysLog("Backup failed: " .. tostring(err), false, true)
                    end
                end)
            else
                sysLog("Error: load scriptLibrary package first using 'get package(\"scriptLibrary\")'.", false, true)
            end
        else
            sysLog("Package '" .. pkgName .. "' is not recognized for system-save.", false, true)
        end

    -- Save single script using precise static filenames
    elseif raw:match("^save package (%d+)$") then
        found = true
        local idx = tonumber(raw:match("^save package (%d+)$"))
        if loadedLibrary and loadedLibrary.Catalog and loadedLibrary.Catalog[idx] then
            local scriptItem = loadedLibrary.Catalog[idx]
            sysLog("Compiling standalone save for: " .. scriptItem.Name, true)
            task.spawn(function()
                local success, err = pcall(function()
                    if writefile then
                        local codeToWrite = scriptItem.RawCode or "-- No execution strings registered."
                        local safeName = LibraryMappings[idx] or (scriptItem.Name:gsub("%s+", "_") .. ".lua")
                        
                        writefile(safeName, codeToWrite)
                        sysLog("SUCCESS: Standalone saved as '" .. safeName .. "'!", true)
                    else
                        error("Executor does not support writefile API")
                    end
                end)
                if not success then
                    sysLog("Failed standalone save: " .. tostring(err), false, true)
                end
            end)
        else
            sysLog("Error: Invalid index or scriptLibrary package is not loaded yet.", false, true)
        end

    -- --- DYNAMIC PACKAGE LIBRARY LOADING ---
    elseif raw:match('^get package%("([%w_]+)"%)') then
        found = true
        local pkgName = originalRaw:match('get package%("([%w_]+)"%)')
        
        if pkgName == "scriptLibrary" then
            sysLog("Fetching package 'scriptLibrary' from database...", true)
            task.spawn(function()
                local success, lib = pcall(function()
                    return loadstring(game:HttpGet("https://raw.githubusercontent.com/H4T0-debug/Terminal_V5/refs/heads/main/scriptLibrary"))()
                end)
                
                if success and lib and lib.Catalog then
                    loadedLibrary = lib
