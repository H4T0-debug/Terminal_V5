function API.SearchScriptBlox(query)
    for _, child in pairs(uiRef.BloxScroll:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    local requestFunc = (syn and syn.request) or (http and http.request) or http_request or request
    if not requestFunc then return end
    
    task.spawn(function()
        local url = "https://scriptblox.com/api/script/search?q=" .. HttpService:UrlEncode(query) .. "&mode=free"
        local response = requestFunc({Url = url, Method = "GET"})
        if response.Success then
            local data = HttpService:JSONDecode(response.Body)
            if data and data.result and data.result.scripts then
                for _, s in pairs(data.result.scripts) do
                    local btn = Instance.new("TextButton", uiRef.BloxScroll)
                    btn.Size = UDim2.new(1, -10, 0, 50)
                    btn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
                    btn.Text = "<b>" .. s.title .. "</b>\nClick to execute loadstring"
                    btn.TextColor3 = Color3.new(1, 1, 1)
                    btn.TextSize = 14
                    btn.RichText = true
                    btn.FontFace = Font.fromId(12187374765)
                    Instance.new("UICorner", btn)
                    btn.MouseButton1Click:Connect(function()
                        local success, err = pcall(function() loadstring(s.script)() end)
                        if not success then warn("ScriptBlox Error: " .. tostring(err)) end
                    end)
                end
            end
        end
    end)
end

function API.ExecuteCommand(rawInput)
    local originalRaw = rawInput:gsub("^%s+", ""):gsub("%s+$", "")
    if originalRaw == "" then return end

    if LoadstringConverter then
        local wasHandled, errorResult = pcall(function()
            return LoadstringConverter.CleanAndExecute(originalRaw, printMsg)
        end)
        if wasHandled and errorResult then return end
    end

    local raw = originalRaw:lower()
    printMsg("$ " .. raw, false)
    local found = false
    
    if raw == "control area" then found = true; createShield()
    
    elseif raw:sub(1,11) == "change rgb " then
        found = true
        local colorArgs = originalRaw:sub(12):gsub("%s+", "")
        local split = colorArgs:split(",")
        local color1Name, color2Name = split[1], split[2]
        
        if color1Name and color2Name and ColorPicker and uiRef.LedGradient then
            -- Fetch the mapped Color3 instances from your remote module
            local c1 = ColorPicker.GetColor(color1Name)
            local c2 = ColorPicker.GetColor(color2Name)
            
            if c1 and c2 then
                -- Dynamically reconstruct the Gradient configuration
                uiRef.LedGradient.Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0.00, c1),
                    ColorSequenceKeypoint.new(0.25, c2),
                    ColorSequenceKeypoint.new(0.50, c1),
                    ColorSequenceKeypoint.new(0.75, c2),
                    ColorSequenceKeypoint.new(1.00, c1)
                })
                printMsg("RGB LED configuration updated to: " .. color1Name .. " and " .. color2Name, true)
            else
                printMsg("Error: One or both colors not found in color library.", false, true)
            end
        else
            printMsg("Syntax Error: Use 'change rgb color1,color2' (e.g. change rgb red,blue)", false, true)
        end
        
    elseif raw == "start data index" then
        found = true; print(player.DisplayName .. ":UTF-70:freemium")
        printMsg("Data Indexing: ACTIVATED (Signal Sent)", true)
    elseif raw == "stop data index" then
        found = true; print(player.DisplayName .. ":UTF-71:free")
        printMsg("Data Indexing: DEACTIVATED (Signal Sent)", true)
    elseif raw == "protocol 2" then
        found = true; printMsg("Protocol 2: EVASION SEQUENCE START.", true)
        task.spawn(function()
            task.wait(0.5); workspace.FallenPartsDestroyHeight = -100000
            if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                local oldCF = player.Character.HumanoidRootPart.CFrame
                player.Character.HumanoidRootPart.CFrame = CFrame.new(oldCF.X, -10000, oldCF.Z)
                task.wait(10); player.Character.HumanoidRootPart.CFrame = SHIELD_CENTER_CF
                printMsg("Protocol 2: Returned to HQ.", true)
            end
        end)
    elseif raw == "enable chat mode" then
        found = true; states.chatMode = true
        if connections.chatListener then connections.chatListener:Disconnect() end
        connections.chatListener = player.Chated or player.Chatted:Connect(function(msg)
            if states.chatMode and msg:sub(1,1) == "$" then API.ExecuteCommand(msg:sub(2)) end
        end)
        printMsg("Chat Mode: ENABLED. Use '$' in game chat.", true)
    elseif raw == "disable chat mode" then
        found = true; states.chatMode = false; if connections.chatListener then connections.chatListener:Disconnect() end; printMsg("Chat Mode: DISABLED.", true)
    elseif raw == "tp mn" then
        found = true; states.waitingForMn = true; printMsg("Waiting for Flowing Water (Console Move)...", true)
    elseif raw == "tp pas" then
        found = true; states.waitingForPas = true; printMsg("Waiting for Flowing Water (Console Move) for PAS...", true)
    elseif raw == "protocol 1" then
        found = true; states.protocol1 = not states.protocol1; printMsg("Protocol 1: " .. (states.protocol1 and "AGGRESSIVE" or "DISABLED"), true)
    elseif raw == "loop fling all" then
        found = true; states.loopFlinging = true; printMsg("Loop Fling All: ACTIVATED", true)
        task.spawn(function()
            while states.loopFlinging do
                for _, target in pairs(Players:GetPlayers()) do
                    if not states.loopFlinging then break end
                    if target ~= player and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
                        local hum = player.Character:FindFirstChildOfClass("Humanoid")
                        local hrp = player.Character:FindFirstChild("HumanoidRootPart")
                        local tHrp = target.Character:FindFirstChild("HumanoidRootPart")
                        if hum and hrp and tHrp then
                            hum:ChangeState(Enum.HumanoidStateType.Physics)
                            for i = 1, 50 do
                                if not target.Character or not states.loopFlinging then break end
                                hrp.Velocity = tHrp.Velocity * 1.5 + Vector3.new(0, 5000, 0)
                                hrp.RotVelocity = Vector3.new(0, 50000, 0)
                                hrp.CFrame = (i % 2 == 0) and tHrp.CFrame or tHrp.CFrame * CFrame.new(0, 0, 0.1)
                                RunService.Heartbeat:Wait()
                            end
                            hrp.RotVelocity = Vector3.zero; hrp.Velocity = Vector3.zero; hum:ChangeState(Enum.HumanoidStateType.GettingUp)
                        end
                    end
                end
                task.wait(0.5)
            end
        end)
    elseif raw == "stop" then
        found = true; states.loopFlinging = false; states.protocol1 = false; states.waitingForMn = false; states.waitingForPas = false; printMsg("All processes terminated.", true)
    elseif raw == "tp as" then
        found = true; printMsg("Searching for Atoms Domain...", true)
        local target = findObjectDeep(DOMAIN_AS)
        if target then
            player.Character:SetPrimaryPartCFrame(target:GetPivot() * CFrame.new(0, 5, 0))
            printMsg("Domain 'Atoms' reached.", true)
        else printMsg("Error: Atoms not found.", false, true) end
    elseif raw == "tp cr" then
        found = true; printMsg("Searching for Cutscene Domain...", true)
        local target = findObjectDeep(DOMAIN_CR)
        if target then
            player.Character:SetPrimaryPartCFrame(target:GetPivot() * CFrame.new(0, 5, 0))
            printMsg("Domain 'Death Cutscene' reached.", true)
        else printMsg("Error: Cutscene not found.", false, true) end
    elseif raw == "enable fling aura" then
        found = true; states.flingAura = true
        if connections.aura then connections.aura:Disconnect() end
        connections.aura = RunService.Heartbeat:Connect(function()
            local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if hrp and states.flingAura then
                local oldV, oldRV = hrp.Velocity, hrp.RotVelocity
                for _, p in pairs(Players:GetPlayers()) do
                    if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                        if (hrp.Position - p.Character.HumanoidRootPart.Position).Magnitude < 4 then
                            hrp.Velocity = Vector3.new(AURA_POWER, AURA_POWER, AURA_POWER)
                            hrp.RotVelocity = Vector3.new(AURA_POWER, AURA_POWER, AURA_POWER)
                            RunService.RenderStepped:Wait()
                            hrp.Velocity = oldV; hrp.RotVelocity = oldRV
                        end
                    end
                end
            end
        end)
        printMsg("Fling Aura Active (50k Power)", true)
    elseif raw == "disable fling aura" then
        found = true; states.flingAura = false; if connections.aura then connections.aura:Disconnect() end; printMsg("Fling Aura Disabled.", true)
    elseif raw:sub(1,6) == "fling " then
        found = true; local cmdStr = raw:sub(7); local tName, hits
        if cmdStr:find(":") then local split = cmdStr:split(":") tName = split[1] hits = tonumber(split[2]) or 10 else tName = cmdStr hits = 10 end
        local target = getPlayer(tName)
        if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
            printMsg("Flinging " .. target.DisplayName, true)
            task.spawn(function()
                states.flinging = true
                local hum = player.Character:FindFirstChildOfClass("Humanoid")
                local hrp = player.Character:FindFirstChild("HumanoidRootPart")
                local tHrp = target.Character.HumanoidRootPart
                if hum and hrp then
                    hum:ChangeState(Enum.HumanoidStateType.Physics)
                    for i = 1, hits * 10 do 
                        if not target.Character then break end
                        hrp.Velocity = tHrp.Velocity * 2 + Vector3.new(0, 8000, 0)
                        hrp.RotVelocity = Vector3.new(0, 80000, 0)
                        hrp.CFrame = (i % 2 == 0) and tHrp.CFrame or tHrp.CFrame * CFrame.new(0, 0.05, 0)
                        RunService.Heartbeat:Wait()
                    end
                    hrp.RotVelocity = Vector3.zero; hrp.Velocity = Vector3.zero; hum:ChangeState(Enum.HumanoidStateType.GettingUp)
                end
                states.flinging = false
            end)
        end
    elseif raw:sub(1,9) == "trashcan " then
        found = true; local target = getPlayer(raw:sub(10))
        if target then states.trashTarget = target; states.trashLooping = true; printMsg("Trash Target: " .. target.DisplayName, true); local t = getNearestTrashcan(); if t then player.Character.HumanoidRootPart.CFrame = t.CFrame * CFrame.new(3,0,0) end end
    elseif raw == "stop trashcan" then
        found = true; states.trashLooping = false; states.isAttached = false; printMsg("Trash Loop Halted.", true)
    elseif raw == "enable antifling" then
        found = true; states.antifling = true
        if connections.safePosTracker then connections.safePosTracker:Disconnect() end
        connections.safePosTracker = RunService.Heartbeat:Connect(function()
            local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if hrp and not states.flinging then
                if hrp.Position.Y < 800 and hrp.Position.Y > -500 then states.lastSafePos = hrp.CFrame end
            end
        end)
        if connections.antifling then connections.antifling:Disconnect() end
        connections.antifling = RunService.Heartbeat:Connect(function()
            local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if hrp and states.antifling then
                if hrp.Position.Y >= 1000 then
                    local returnTarget = states.lastSafePos 
                    printMsg("Fling Detected! Quarantining at MN for 10s.", true)
                    hrp.CFrame = MN_CF; hrp.Anchored = true
                    task.delay(10, function() 
                        hrp.Anchored = false; hrp.CFrame = returnTarget
                        printMsg("Sequence Complete: Returned to safety.", true)
                    end)
                end
            end
        end)
        printMsg("Smart Anti-Fling Enabled.", true)
    elseif raw == "disable antifling" then
        found = true; states.antifling = false; 
        if connections.antifling then connections.antifling:Disconnect() end
        if connections.safePosTracker then connections.safePosTracker:Disconnect() end
        printMsg("Anti-Fling Disabled.", true)
    elseif raw == "enable esp" then
        found = true; states.esp = true
        task.spawn(function() while states.esp do for _, p in pairs(Players:GetPlayers()) do if p ~= player and p.Character and not p.Character:FindFirstChild("TerminalESP") then local h = Instance.new("Highlight", p.Character) h.Name = "TerminalESP" h.FillColor = Color3.new(0, 1, 1) end end task.wait(1) end end)
        printMsg("ESP Enabled.", true)
    elseif raw == "clear" then
        found = true; uiRef.OutputLabel.Text = "[SYSTEM] Console Cleared."
    end
    if not found then printMsg("Error: command doesn't exist.", false, true) end
end

-- --- UNIFIED JSON COMMAND DECODER & RECEIVER ---
function API.ReceiveJSON(jsonString)
    local success, packet = pcall(function()
        return HttpService:JSONDecode(jsonString)
    end)
    
    if success and packet and packet.type and packet.data then
        if packet.type == "command" then
            API.ExecuteCommand(packet.data)
        elseif packet.type == "ai" then
            API.AskAI(packet.data)
        elseif packet.type == "search" then
            API.SearchScriptBlox(packet.data)
        end
    else
        warn("[CMD PROCESSOR]: Invalid or corrupted JSON packet received.")
    end
end

-- --- INITIALIZATION PIPELINE ---
function CommandProcessor.Init(uidefs)
    uiRef = uidefs
    
    -- Setup Core Hooks
    task.spawn(function()
        local function setupHook()
            local char = player.Character or player.CharacterAdded:Wait()
            local comms = char:WaitForChild("Communicate", 10)
            if comms and comms:IsA("RemoteEvent") then
                local old; old = hookmetamethod(game, "__namecall", function(self, ...)
                    local args = {...}
                    if self == comms and getnamecallmethod() == "FireServer" then
                        if states.trashLooping then
                            local g = args[1].Goal
                            if g == "LeftClick" and not states.trashCooldown then 
                                task.spawn(function() task.wait(0.1); if states.trashTarget then states.isAttached = true end end)
                            elseif g == "LeftClickRelease" then 
                                states.isAttached = false; states.trashCooldown = true; 
                                task.spawn(function() task.wait(2.2); local t = getNearestTrashcan(); if t and player.Character then player.Character.HumanoidRootPart.CFrame = t.CFrame * CFrame.new(3, 0, 0) end; states.trashCooldown = false end) 
                            end
                        end
                        if args[1] and args[1].Goal == "Console Move" then
                            if states.waitingForMn then
                                states.waitingForMn = false
                                printMsg("Signal detected. Teleporting (MN) in 0.7s...", true)
                                task.delay(0.7, function()
                                    if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then player.Character.HumanoidRootPart.CFrame = MN_CF end
                                end)
                            elseif states.waitingForPas then
                                states.waitingForPas = false
                                printMsg("Signal detected. Teleporting (PAS) in 0.7s...", true)
                                task.delay(0.7, function()
                                    if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then player.Character.HumanoidRootPart.CFrame = CFrame.new(1073.91443, 16.4270039 + 5, 22984.873, 1, 0, 0, 0, 1, 0, 0, 0, 1) end
                                end)
                            end
                        end
                    end
                    return old(self, ...)
                end)
            end
        end
        setupHook(); player.CharacterAdded:Connect(setupHook)
    end)

    -- Running render loops
    RunService.RenderStepped:Connect(function()
        if states.protocol1 and player.Character then
            local hum = player.Character:FindFirstChildOfClass("Humanoid")
            if hum then hum.WalkSpeed, hum.JumpPower, hum.PlatformStand = 16, 50, false end
        end
        local hum = player.Character and player.Character:FindFirstChild("Humanoid")
        if hum and shieldInstance and shieldInstance.Parent then
            local hpPercent = hum.Health / hum.MaxHealth
            hum.WalkSpeed = (hpPercent <= 0.2) and 616 or 116
        end
    end)

    RunService.Heartbeat:Connect(function()
        if shieldInstance and shieldInstance.Parent and player.Character then
            local hrp = player.Character:FindFirstChild("HumanoidRootPart")
            if hrp and (hrp.Position - SHIELD_CENTER_CF.Position).Magnitude > 1000 then
                hrp.CFrame = SHIELD_CENTER_CF; hrp.Velocity = Vector3.zero
            end
        end
        if states.isAttached and states.trashTarget and states.trashTarget.Character then 
            local hrp, tHrp = player.Character:FindFirstChild("HumanoidRootPart"), states.trashTarget.Character:FindFirstChild("HumanoidRootPart")
            if hrp and tHrp then hrp.CFrame = tHrp.CFrame * CFrame.new(0, 0, 1.8); hrp.Velocity = Vector3.zero end 
        end 
    end)

    -- Start Scraper loop
    if DataScraper then
        local nextObj = DataScraper.GetHierarchyGenerator()
        DataScraper.ListenForSignals()

        task.spawn(function()
            while true do
                if DataScraper.IsIndexingEnabled() then
                    local payload = nextObj()
                    if payload then 
                        states.lastScrapedData = payload 
                        silentDataFeed(payload) 
                    end
                end
                task.wait(10)
            end
        end)
    end

    return API
end

return CommandProcessor