-- --- UTILITY METHODS ---
local function printMsg(msg, isSystem, isError)
    if not uiRef.OutputLabel then return end
    local color = isError and "rgb(255, 100, 100)" or (isSystem and "rgb(0, 255, 255)" or "rgb(0, 255, 0)")
    uiRef.OutputLabel.Text = uiRef.OutputLabel.Text .. string.format("\n<font color='%s'>%s%s</font>", color, isSystem and "[SYSTEM] " or "", msg)
    task.wait(0.05)
    uiRef.CmdScroll.CanvasPosition = Vector2.new(0, 99999)
end

local function getPlayer(name)
    name = name:lower():gsub("%s+", "")
    for _, p in pairs(Players:GetPlayers()) do
        if p.Name:lower():sub(1, #name) == name or p.DisplayName:lower():sub(1, #name) == name then
            return p
        end
    end
    return nil
end

local function findObjectDeep(name)
    for _, obj in pairs(game:GetDescendants()) do
        if obj.Name == name and (obj:IsA("BasePart") or obj:IsA("Model")) then
            return obj
        end
    end
    return nil
end

local function getNearestTrashcan()
    local nearest = nil
    local shortestDist = 1000
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Name:lower() == TRASH_NAME then
            if obj.Transparency < 1 and obj.CanCollide == true then
                local isHeld = false
                for _, p in pairs(Players:GetPlayers()) do
                    if p.Character and obj:IsDescendantOf(p.Character) then isHeld = true break end
                end
                if not isHeld then
                    local dist = (hrp.Position - obj.Position).Magnitude
                    if dist < shortestDist then shortestDist = dist nearest = obj end
                end
            end
        end
    end
    return nearest
end

local function extractCode(text)
    local pattern = "```lua\n(.-)\n```"
    local code = text:match(pattern)
    if not code then
        pattern = "```\n(.-)\n```"
        code = text:match(pattern)
    end
    return code
end

-- --- SHIELD SYSTEM ---
local function createShield()
    if shieldInstance then shieldInstance:Destroy() end
    local success, result = pcall(function() return game:GetObjects(SHIELD_ID) end)
    if success and result[1] then
        shieldInstance = result[1]; shieldInstance.Name = "EnergyShield"; shieldInstance.Parent = workspace
        local function setup(obj) if obj:IsA("BasePart") then obj.CanCollide = false; obj.CanQuery = false; obj.Anchored = true end end
        if shieldInstance:IsA("BasePart") then shieldInstance.CFrame = CFrame.new(CENTER_POS); setup(shieldInstance)
        elseif shieldInstance:IsA("Model") then shieldInstance:PivotTo(CFrame.new(CENTER_POS)); for _, p in pairs(shieldInstance:GetDescendants()) do setup(p) end end
        printMsg("Control Area shield deployed.", true)
    else printMsg("Error: Shield load failed.", false, true) end
end

