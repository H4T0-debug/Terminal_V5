-- Custom Drag Handler for Square Toggle
local dragging = false
local dragInput
local dragStart
local startPos
local moved = false

toggleSquare.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        moved = false
        dragStart = input.Position
        startPos = toggleSquare.Position

        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
                if not moved then
                    toggleSquare.Visible = false
                    if _G.CurrentUITheme == "cli" then
                        cliUI.Visible = true
                    else
                        defaultUI.Visible = true
                    end
                end
            end
        end)
    end
end)

toggleSquare.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        if delta.Magnitude > 5 then
            moved = true
        end
        toggleSquare.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

