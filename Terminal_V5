-- --- INITIALIZATION SEQUENCER ---
local function triggerInitialization()
    printDefaultLine("Terminal V5.0", Color3.fromRGB(0, 160, 255))
    task.wait(0.3)
    printDefaultLine("Initializing modules...", Color3.fromRGB(0, 160, 255))
    task.wait(0.8) -- Emulating load sequence asynchronously
    
    if systemAPI then
        printDefaultLine("Initialization successful.", Color3.fromRGB(0, 160, 255))
        task.wait(0.4)
        
        -- SCANNING FOR BACKUPS LOCALLY
        printDefaultLine("Scanning local filesystem backups...", Color3.fromRGB(0, 160, 255))
        task.wait(0.5)
        local backupsFound = {}
        local backupMappings = {
            "Hiru_Hub.lua", "QuantumOnyx_Project.lua", "Ringta_Scripts_(Patched).lua",
            "Redz_Hub_(Beta).lua", "Zee_Hub.lua", "Dex_Explorer.lua", "ThanHub.lua",
            "NatHub.lua", "H4X_Hub.lua", "Infinite_Yield_FE.lua", "Gravity_Hub.lua",
            "Terminal_V5.0.lua", "FoxName.lua", "Ringta_Hub_V2.lua", "Vape_Voidware.lua",
            "script_library_backup.lua"
        }
        for _, file in ipairs(backupMappings) do
            if isfile and isfile(file) then
                table.insert(backupsFound, file)
            end
        end
        if #backupsFound > 0 then
            printDefaultLine("Found (" .. tostring(#backupsFound) .. ") local script backups:", Color3.fromRGB(0, 160, 255))
            for _, backup in ipairs(backupsFound) do
                printDefaultLine(" - " .. backup, Color3.fromRGB(0, 160, 255))
            end
        else
            printDefaultLine("No local script backups detected.", Color3.fromRGB(0, 160, 255))
        end
        task.wait(0.4)

        printDefaultLine("Fetching game data...", Color3.fromRGB(0, 160, 255))
        task.wait(0.8)
        
        -- Scanning for Remotes
        local remotes = 0
        for _, obj in pairs(game:GetDescendants()) do
            if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
                remotes = remotes + 1
            end
        end
        
        printDefaultLine("Fetching game data successful. Found (" .. tostring(remotes) .. ") active secure ports.", Color3.fromRGB(0, 160, 255))
        task.wait(0.5)
        printDefaultLine("Waiting for server information...", Color3.fromRGB(0, 160, 255))
        task.wait(0.7)
        
        -- Print statistics
        printDefaultLine("Current server information:", Color3.fromRGB(0, 160, 255))
        printDefaultLine("Total player: " .. tostring(#Players:GetPlayers()), Color3.fromRGB(0, 160, 255))
        printDefaultLine("Current player names:", Color3.fromRGB(0, 160, 255))
        for i, p in ipairs(Players:GetPlayers()) do
            printDefaultLine(tostring(i) .. ". " .. p.DisplayName .. " (@" .. p.Name .. ")", Color3.fromRGB(0, 160, 255))
        end
        printDefaultLine("Server Place ID: " .. tostring(game.PlaceId), Color3.fromRGB(0, 160, 255))
        printDefaultLine("Server Job ID: " .. tostring(game.JobId), Color3.fromRGB(0, 160, 255))
    else
        printDefaultLine("Initialization failed. Verification mismatch.", Color3.fromRGB(255, 50, 50))
    end
end
task.spawn(triggerInitialization)

