local DataScraper = {}
local indexingEnabled = false
local Players = game:GetService("Players")
local LogService = game:GetService("LogService")
local HttpService = game:GetService("HttpService") -- Required for JSON conversion
local player = Players.LocalPlayer

function DataScraper.IsIndexingEnabled()
    return indexingEnabled
end

-- New Helper: Packages up real-time metadata into a clean JSON packet for aiMemory
function DataScraper.SendStateToMemory(actionName, detailedTable)
    if not _G.aiMemory or type(_G.aiMemory.WriteSlot) ~= "function" then return end
    
    local packet = {
        event = actionName or "DATA_LOG",
        sender = "DataIndex_V5",
        timestamp = os.time(),
        player = player.Name,
        details = detailedTable or {}
    }
    
    local success, jsonString = pcall(function()
        return HttpService:JSONEncode(packet)
    end)
    
    if success then
        _G.aiMemory.WriteSlot(jsonString)
    else
        warn("[DATA INDEX]: Failed to encode state string.")
    end
end

local function processMessage(message)
    local displayName = player.DisplayName
    if message:find(displayName) then
        if message:find("UTF%-70:freemium") then
            indexingEnabled = true
            warn("[DATA INDEX]: SIGNAL RECEIVED - STARTING SCRAPER")
            
            -- Log the signal event as JSON to memory
            DataScraper.SendStateToMemory("SCRAPER_START", {status = "Active"})
        elseif message:find("UTF%-71:free") then
            indexingEnabled = false
            warn("[DATA INDEX]: SIGNAL RECEIVED - STOPPING SCRAPER")
            
            -- Log the signal event as JSON to memory
            DataScraper.SendStateToMemory("SCRAPER_STOP", {status = "Inactive"})
        end
    end
end

function DataScraper.ListenForSignals()
    LogService.MessageOut:Connect(function(message, messageType)
        processMessage(message)
    end)

    task.spawn(function()
        while true do
            local logs = LogService:GetLogHistory()
            for i = #logs, math.max(1, #logs - 5), -1 do
                processMessage(logs[i].message)
            end
            task.wait(1) 
        end
    end)
end

return DataScraper