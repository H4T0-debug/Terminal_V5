local DataScraper = {}
local indexingEnabled = false
local Players = game:GetService("Players")
local LogService = game:GetService("LogService")
local HttpService = game:GetService("HttpService")
local player = Players.LocalPlayer

-- Dynamically connect to local AI Memory module
local AiMemory = nil
pcall(function()
    AiMemory = loadstring(game:HttpGet("https://raw.githubusercontent.com/H4T0-debug/Terminal_V5/refs/heads/main/aiMemory"))()
end)

local function getChildNames(obj)
    local children = obj:GetChildren()
    local names = {}
    for i = 1, math.min(#children, 10) do
        table.insert(names, children[i].Name)
    end
    return #names > 0 and table.concat(names, ", ") .. (#children > 10 and "..." or "") or "None"
end

function DataScraper.IsIndexingEnabled()
    return indexingEnabled
end

-- Improved signal detection logic
local function processMessage(message)
    local displayName = player.DisplayName
    if message:find(displayName) then
        if message:find("UTF%-70:freemium") then
            indexingEnabled = true
            warn("[DATA INDEX]: SIGNAL RECEIVED - STARTING SCRAPER")
            if AiMemory then
                local jsonSignal = HttpService:JSONEncode({
                    status = "INDEXING_START",
                    timestamp = os.time(),
                    agent = player.Name
                })
                AiMemory.WriteMemory("last_scraped_signal", jsonSignal)
            end
        elseif message:find("UTF%-71:free") then
            indexingEnabled = false
            warn("[DATA INDEX]: SIGNAL RECEIVED - STOPPING SCRAPER")
            if AiMemory then
                local jsonSignal = HttpService:JSONEncode({
                    status = "INDEXING_STOP",
                    timestamp = os.time(),
                    agent = player.Name
                })
                AiMemory.WriteMemory("last_scraped_signal", jsonSignal)
            end
        end
    end
end

function DataScraper.ListenForSignals()
    LogService.MessageOut:Connect(function(message, messageType)
        processMessage(message)
    end)

    task.spawn(function()
        while true do
            local logs = LogService:GetLogHistory()
            for i = #logs, math.max(1, #logs - 5), -1 do
                processMessage(logs[i].message)
            end
            task.wait(1) 
        end
    end)
end

function DataScraper.GetHierarchyGenerator()
    local instances = game:GetDescendants()
    local index = 0

    return function()
        index = index + 1
        local obj = instances[index]

        if not obj then return nil end

        if obj:IsA("MeshPart") or obj:IsA("TouchTransmitter") or obj:IsA("BasePart") and obj.Transparency == 1 then 
            return DataScraper.GetHierarchyGenerator()() 
        end

        local success, result = pcall(function()
            -- Format scraped data properties into structured JSON payload
            local dataTable = {
                className = obj.ClassName,
                name = obj.Name,
                parent = obj.Parent and obj.Parent.Name or "NULL",
                childModules = getChildNames(obj)
            }
            return HttpService:JSONEncode(dataTable)
        end)

        return success and result or nil
    end
end

return DataScraper