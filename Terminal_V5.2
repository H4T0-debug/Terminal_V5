-- AI Request Function
local function askAI(message)
    -- Trigger built-in executor if user mentions "run this code"
    if message:lower():find("run this code") then
        aiOutput.Text = aiOutput.Text .. "\n\n<b>" .. player.Name .. ":</b> " .. message
        if states.lastAiCode ~= "" then
            aiOutput.Text = aiOutput.Text .. "\n<b>Termin:</b> Executing cached script..."
            aiScroll.CanvasPosition = Vector2.new(0, 99999)
            local success, err = pcall(function()
                local func = loadstring(states.lastAiCode)
                if func then
                    task.spawn(func)
                else
                    error("Failed to load script (Syntax Error)")
                end
            end)
            if success then
                aiOutput.Text = aiOutput.Text .. "\n<b>Termin:</b> Script executed successfully."
            else
                aiOutput.Text = aiOutput.Text .. "\n<b>Termin:</b> Execution Error: " .. tostring(err)
            end
        else
            aiOutput.Text = aiOutput.Text .. "\n<b>Termin:</b> Error: No script found in previous message to execute."
        end
        aiScroll.CanvasPosition = Vector2.new(0, 99999)
        return
    end

	aiOutput.Text = aiOutput.Text .. "\n\n<b>" .. player.Name .. ":</b> " .. message
	aiOutput.Text = aiOutput.Text .. "\n<b>Termin:</b> <i>Thinking...</i>"
	aiScroll.CanvasPosition = Vector2.new(0, 99999)

	task.spawn(function()
		local requestFunc = (syn and syn.request) or (http and http.request) or http_request or request
		if not requestFunc then 
			aiOutput.Text = aiOutput.Text:gsub("\n<b>Termin:</b> <i>Thinking.*</i>", "\n<b>Termin:</b> Error: Executor does not support requests.")
			return 
		end

		local response = requestFunc({
			Url = "https://openrouter.ai/api/v1/chat/completions",
			Method = "POST",
			Headers = {
				["Content-Type"] = "application/json",
				["Authorization"] = "Bearer " .. OPENROUTER_KEY,
                ["HTTP-Referer"] = "https://roblox.com",
                ["X-Title"] = "Roblox Terminal"
			},
			Body = HttpService:JSONEncode({
				model = "nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free", 
				messages = {
                    {
                        role = "system", 
                        content = "You are Termin AI. You are integrated into Terminal V5.0. You receive live game hierarchy data. ALWAYS reference the data provided in the user's message as it is current. Identify vulnerabilities or scripts. IMPORTANT: Only provide scripts in ```lua ... ``` blocks."
                    },
					{role = "user", content = "CURRENT_GAME_DATA: " .. states.lastScrapedData .. "\n\nUSER_MESSAGE: " .. message}
				},
				max_tokens = 1000
			}),
            Timeout = 60
		})

		if response.Success then
            if not response.Body or response.Body == "" then
                aiOutput.Text = aiOutput.Text:gsub("\n<b>Termin:</b> <i>Thinking.*</i>", "\n<b>Termin:</b> Empty response body received.")
                return
            end

			local success, data = pcall(function() return HttpService:JSONDecode(response.Body) end)
            if success and data and data.choices and data.choices[1] and data.choices[1].message then
                local msgData = data.choices[1].message
			    local reply = msgData.content or ""
                
                if reply == "" then
                    aiOutput.Text = aiOutput.Text:gsub("\n<b>Termin:</b> <i>Thinking.*</i>", "\n<b>Termin:</b> Model returned a response but the content field was empty.")
                else
                    local foundCode = extractCode(reply)
                    if foundCode then states.lastAiCode = foundCode end
                    
			        aiOutput.Text = aiOutput.Text:gsub("\n<b>Termin:</b> <i>Thinking.*</i>", "\n<b>Termin:</b> " .. reply)
                end
            else
                local rawSnippet = string.sub(response.Body or "N/A", 1, 100)
                aiOutput.Text = aiOutput.Text:gsub("\n<b>Termin:</b> <i>Thinking.*</i>", "\n<b>Termin:</b> Parse Error. Raw: " .. rawSnippet)
            end
		else
            local errorMsg = "Request Failed"
            pcall(function()
                if response.Body then
                    local data = HttpService:JSONDecode(response.Body)
                    if data.error and data.error.message then errorMsg = data.error.message end
                end
            end)
			aiOutput.Text = aiOutput.Text:gsub("\n<b>Termin:</b> <i>Thinking.*</i>", "\n<b>Termin:</b> API Error: " .. errorMsg)
		end
		aiScroll.CanvasPosition = Vector2.new(0, 99999)
	end)
end

